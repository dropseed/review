{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Review",
  "mainBinaryName": "Review",
  "version": "0.0.80",
  "identifier": "com.dropseed.review",
  "build": {
    "beforeDevCommand": "../scripts/build-cli && ../scripts/start-vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && ../scripts/build-cli",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Loading...",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "tabbingIdentifier": "review-main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "externalBin": ["binaries/review-cli"],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "fileAssociations": [
      {
        "ext": ["txt", "md", "json", "yaml", "yml", "toml"],
        "mimeType": "text/plain",
        "role": "Viewer",
        "description": "Text file"
      },
      {
        "ext": ["rs"],
        "mimeType": "text/x-rust",
        "role": "Viewer",
        "description": "Rust source file"
      },
      {
        "ext": ["ts", "tsx"],
        "mimeType": "text/x-typescript",
        "role": "Viewer",
        "description": "TypeScript source file"
      },
      {
        "ext": ["js", "jsx"],
        "mimeType": "text/javascript",
        "role": "Viewer",
        "description": "JavaScript source file"
      },
      {
        "ext": ["py"],
        "mimeType": "text/x-python",
        "role": "Viewer",
        "description": "Python source file"
      },
      {
        "ext": ["go"],
        "mimeType": "text/x-go",
        "role": "Viewer",
        "description": "Go source file"
      },
      {
        "ext": ["rb"],
        "mimeType": "text/x-ruby",
        "role": "Viewer",
        "description": "Ruby source file"
      },
      {
        "ext": ["java"],
        "mimeType": "text/x-java",
        "role": "Viewer",
        "description": "Java source file"
      },
      {
        "ext": ["c", "h"],
        "mimeType": "text/x-c",
        "role": "Viewer",
        "description": "C source file"
      },
      {
        "ext": ["cpp"],
        "mimeType": "text/x-c++src",
        "role": "Viewer",
        "description": "C++ source file"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlENDJDN0U1RTAxMzlBOTMKUldTVG1oUGc1Y2RDbmZpeVMxS0wrUGxpdDFWaitsVFdMMm5uTWtHYitUbFV3cFJhOUQvVisrb0UK",
      "endpoints": [
        "https://github.com/dropseed/review/releases/latest/download/latest.json"
      ]
    }
  }
}
